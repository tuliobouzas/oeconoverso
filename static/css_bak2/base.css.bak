/** GLOBAL THEME & TYPOGRAPHY **/

@import url('https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Libre+Caslon+Text:ital,wght@0,400;0,700;1,400&family=Ultra&display=swap');
@import url('https://fonts.googleapis.com/css2?family=Manufacturing+Consent&family=Monoton&family=Six+Caps&display=swap');

/* Whole document */
html { 
  height: 100%; 
  background-color: var(--menubar-color);
}

/* BODY OF THE DOCUMENT */
body { 
  font-family: var(--body-font); 
  font-size: var(--body-font-size);          
  letter-spacing: 0.5px; 
  margin: 0; 
  padding: 0;                  
  min-height: 100vh;
  display: flex; 
  flex-direction: column;
  background: var(--bg-color);
  color: var(--body-color);
  transition: background 0.3s, color 0.3s;
}

h1, h2, h3, h4, h5, h6 {
  font-family: var(--title-font);
  color: var(--body-color);
}

.article-title, .article-title a {
  font-family: var(--manchete-font) !important;
  font-weight: normal;
  color: inherit;
  text-decoration: none;
}

article.info h1.article-title {
  font-size: var(--title-single-size);
  line-height: 1.1;
  margin-bottom: var(--element-gap);
}

/* Gazeta List Headlines */
.gazeta-list-title {
  font-family: var(--manchete-font) !important;
  font-size: var(--headline-size);
  line-height: 1.1;
  margin-top: 0;
  margin-bottom: var(--element-gap);
  text-align: left;
}

.gazeta-list-title a {
  color: var(--body-color);
  text-decoration: none;
}

.section-title, .section-title a {
  font-family: var(--section-font) !important;
  font-size: var(--section-title-size);
  line-height: 1.1;
  font-weight: normal;
  color: inherit;
  text-decoration: none;
}

/* title of the page (Logo) */
.title { 
  padding-top: var(--header-padding);
  padding-bottom: var(--header-padding);
  text-align: center; 
}   

.title-logo {
    max-width: 525px;
    width: 90%;
    height: auto;
    filter: var(--svg-filter);
    transition: filter 0.3s;
}

/* newspaper date bar */
.newspaper-bar {
  width: calc(100% - var(--side-padding)); 
  margin: 0 auto 15px auto;
  text-align: center;
}

.newspaper-date {
  font-family: var(--body-font);
  color: var(--body-color);
  font-size: var(--body-font-size);
}   

/* markdown font */
.markdown-font { 
  font-family: var(--body-font);
  color: var(--body-color); 
  font-size: var(--body-font-size); 
}

/* Links */
a { 
  color: var(--link-color); 
  text-decoration: underline;
}

.manchete-meta {
    font-family: var(--section-font) !important;
    font-size: var(--meta-size);
    color: var(--theme-color-dark);
    margin-bottom: var(--element-gap);
    letter-spacing: 1px;
    width: 90%;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
}

iframe {
  overflow: hidden;
  border: none;
}

/* RESPONSIVE OVERRIDES */

/* Mobile Screens */
@media (max-width: 800px) {
    article.info h1.article-title { font-size: var(--title-single-size-mobile); }
    .gazeta-list-title { font-size: var(--headline-size-mobile); }
    .section-title, .section-title a { font-size: var(--section-title-size-mobile); }
    
    .title {
      padding-top: var(--header-padding);
    }

    .title-logo {
      max-width: 80vw;
    }

    .manchete-meta {
        font-size: var(--meta-size-mobile);
        padding-top: 10px;
    }
}
